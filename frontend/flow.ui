  <property name="styleSheet">
   <string notr="true">#Flow{
	background-color: #191D24;
}

QLabel{
	color: #ffffff;
}

#Flow::separator {
	width: 0.5px;
	height: 0px;
}

#DockTopWidget{
	background-color: #1F232C;
}

#DockTopWidget QPushButton, #clock{
	background-color: #FFA60A;
	border-radius: 9px;
	border: 2px solid #000;
	color: #000;
}

#DockTopWidget QPushButton:hover{
	background-color: #ca8102;
}

#clock{
	padding: 0px 5px;
	font-size: 20px;
	font-weight: bold;
}

#date{
	font-size: 14px;
}

#centralwidget{
	background-color: #2D3340;
}

#PlayerControl{
	background-color: #1F232C;
}

#PlayerControl QPushButton{
	background-color: transparent;
	border: none;
	border-radius: 17px;
}

#PlayerControl QPushButton#btnPlay{
	border-radius: 27px;
}

#PlayerControl QPushButton:hover{
	background-color: #191D24;
}

</string>
